{
  "name": "@remobj/core",
  "version": "0.1.0",
  "main": "dist/remobj.js",
  "module": "dist/remobj.es.js",
  "types": "dist/remobj.d.ts",
  "exports": {
    ".": {
      "types": "./dist/remobj.d.ts",
      "import": "./dist/remobj.es.js",
      "require": "./dist/remobj.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly && npm run api-extract:prod && npm run api-docs",
    "build-local": "vite build && tsc --emitDeclarationOnly && npm run api-extract && npm run api-docs",
    "test": "vitest run tests",
    "coverage": "vitest run tests --coverage",
    "api-extract": "api-extractor run --local",
    "api-extract:prod": "api-extractor run",
    "api-docs": "api-documenter markdown --input-folder temp --output-folder ../../docs/api/core"
  },
  "author": "",
  "license": "PROPRIETARY",
  "description": "",
  "devDependencies": {
    "vitest": "~3.2.4",
    "@microsoft/api-documenter": "~7.26.30",
    "@microsoft/api-extractor": "~7.52.9",
    "vite": "~7.0.6",
    "typescript": "~5.8.3",
    "@vitest/coverage-v8": "~3.2.4",
    "@types/node": "~24.1.0"
  }
}
